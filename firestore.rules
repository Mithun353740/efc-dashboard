rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: players
    // Document ID: uuid
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-100 chars)
    //   - number: string (required, 1-5 chars)
    //   - position: string (required, enum)
    //   - ovr: number (required, 1-100)
    //   - win: number (required)
    //   - loss: number (required)
    //   - draw: number (required)
    //   - goalsScored: number (required)
    //   - goalsConceded: number (required)
    //   - image: string (required, URL)
    //   - form: list (required, strings)
    //   - device: string (required)
    //   - uid: string (required)
    //
    // Collection: leaders
    // Document ID: uuid
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - role: string (required)
    //   - image: string (required, URL)
    //   - quote: string (required)
    //   - initials: string (required)
    //   - playerId: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "mithun47490@gmail.com" ||
        request.auth.token.firebase.sign_in_provider == "anonymous"
      );
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidPlayer(data) {
      return data.id is string &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 100 &&
             data.number is string && data.number.size() >= 1 && data.number.size() <= 10 &&
             data.position in ['FORWARD', 'MIDFIELDER', 'DEFENDER', 'GOALKEEPER'] &&
             data.ovr is number && data.ovr >= 0 && data.ovr <= 100 &&
             data.win is number && data.loss is number && data.draw is number &&
             data.goalsScored is number && data.goalsConceded is number &&
             isValidUrl(data.image) && data.image.size() <= 2000 &&
             data.form is list && data.form.size() <= 10 &&
             data.device is string && data.device.size() <= 50 &&
             data.uid is string && data.uid.size() <= 100;
    }

    function isValidLeader(data) {
      return data.id is string &&
             data.name is string && data.name.size() <= 100 &&
             data.role is string && data.role.size() <= 100 &&
             isValidUrl(data.image) && data.image.size() <= 2000 &&
             data.quote is string && data.quote.size() <= 500 &&
             data.initials is string && data.initials.size() <= 10 &&
             (!('playerId' in data) || (data.playerId is string && data.playerId.size() <= 100));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Players collection
    match /players/{playerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Leaders collection
    match /leaders/{leaderId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
