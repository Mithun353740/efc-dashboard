rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // The main owner (Mithun)
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "mithun47490@gmail.com";
    }

    // Check if the user is an admin. 
    // Currently, we also allow anonymous users WHO ARE LOGGED IN THROUGH THE ADMIN PANEL 
    // to have write access, but this is less secure. 
    // For "Full Proof" security, we rely on the SuperAdmin email.
    function isAdmin() {
      return isSuperAdmin();
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Players collection
    match /players/{playerId} {
      allow read: if true;
      // Admins can manage all players. 
      // Individual players can update their own profile (if we had UID matching enabled).
      // For now, restrict to Admin to prevent guests from messing with stats.
      allow write: if isAdmin();
      
      // Allow partial updates for profile settings (image, device) if they know their ID
      // This is a middle-ground for the current login system.
      allow update: if isAuthenticated() && 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['image', 'device', 'uid']));
    }

    // Leaders collection
    match /leaders/{leaderId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Matches collection
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tournaments collection
    match /tournaments/{tournamentId} {
      allow read: if true;
      // Only admins can create or delete tournaments
      allow create, delete: if isAdmin();
      // Players need to be able to UPDATE a tournament to register (add themselves to 'teams')
      allow update: if isAuthenticated();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Locks subcollection (under settings)
    match /settings/locks/{lockId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
