rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == "mithun47490@gmail.com";
    }

    // A user is an Admin if they are the SuperAdmin OR if they have a registered session in the admins collection
    function isAdmin() {
      return isSuperAdmin() || exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Admins collection (Internal list of authorized sessions)
    match /admins/{uid} {
      allow read: if true;
      // Allow registration if:
      // 1. It's Mithun
      // 2. The session belongs to a player who already has the 'admin' role in their player document
      allow write: if isSuperAdmin() || (
        request.auth.uid == uid && 
        exists(/databases/$(database)/documents/players/$(request.resource.data.playerId)) && 
        get(/databases/$(database)/documents/players/$(request.resource.data.playerId)).data.role == 'admin'
      ) || (
        request.auth.uid == uid && request.resource.data.type == 'master' // Allow password-based master login
      );
    }

    // Players collection
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Allow players to update their own basic profile fields
      allow update: if isAuthenticated() && 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['image', 'device', 'uid', 'email', 'password']));
    }

    // Leaders collection
    match /leaders/{leaderId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Matches collection
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tournaments collection
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated();
    }

    // Settings collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/locks/{lockId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Club Zone V2 Collections ───────────────────────────────────────────

    // Clubs
    match /clubs/{clubId} {
      allow read: if true;
      allow write: if isAdmin() || isAuthenticated();
    }

    // Club Listings (transfer market)
    match /clubListings/{listingId} {
      allow read: if true;
      allow write: if isAdmin() || isAuthenticated();
    }

    // Auction room — all users can watch, only admin can drive
    match /auctions/{auctionId} {
      allow read: if true;
      allow write: if isAdmin() || isAuthenticated(); // owners can write bids/folds
    }

    // Club owner inbox — owner can read their own, anyone authenticated can push
    match /clubInbox/{ownerId} {
      allow read: if request.auth != null && (request.auth.uid == ownerId || isAdmin());
      allow write: if isAuthenticated();
    }

    // Transfer negotiation threads — buyer and seller can read and write their thread
    match /transferThreads/{threadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Internal club seasons — public read, admin write
    match /clubSeasons/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Club fixtures and tournaments
    match /clubFixtures/{fixtureId} {
      allow read: if true;
      allow write: if isAdmin() || isAuthenticated();
    }

    match /clubTournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
