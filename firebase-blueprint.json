{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "An eFootball player in the club",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "number": { "type": "string" },
        "position": { "type": "string" },
        "ovr": { "type": "string" },
        "device": { "type": "string" },
        "uid": { "type": "string" },
        "image": { "type": "string" },
        "win": { "type": "number" },
        "loss": { "type": "number" },
        "draw": { "type": "number" },
        "goalsScored": { "type": "number" },
        "goalsConceded": { "type": "number" },
        "form": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "number"]
    },
    "Leader": {
      "title": "Leader",
      "description": "A leadership figure in the club",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "image": { "type": "string" },
        "quote": { "type": "string" },
        "initials": { "type": "string" },
        "playerId": { "type": "string" }
      },
      "required": ["name", "role"]
    }
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "Player",
      "description": "Collection of eFootball players"
    },
    "/leaders/{leaderId}": {
      "schema": "Leader",
      "description": "Collection of club leaders"
    }
  }
}
